# 智能会议系统后端环境变量模板。
# 复制为 backend/.env 后填写真实值；生产环境建议改为系统环境变量或容器 Secret。

# 数据库：当前开发默认 SQLite；后续正式服务器可切 KingbaseES 适配。
DATABASE_KIND=sqlite
DATABASE_URL=./data/meeting_system.db

# ASR：本地测试先走百炼 DashScope；完全内网部署时改为 remote 并指向 910B/算力服务器 ASR 网关。
ASR_GATEWAY_MODE=dashscope
ASR_GATEWAY_BASE_URL=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_SYNC_MODEL=qwen3-asr-flash
DASHSCOPE_FILETRANS_MODEL=qwen3-asr-flash-filetrans

# 小模型服务：这些地址既可以指向本机，也可以指向算力服务器。
# 服务器部署建议拆端口：VAD CPU、声纹 CPU、强制对齐 GPU。
VAD_GATEWAY_BASE_URL=http://127.0.0.1:8100
VOICEPRINT_GATEWAY_BASE_URL=http://127.0.0.1:8100
ALIGNMENT_GATEWAY_BASE_URL=http://127.0.0.1:8100
MODEL_MOCK_MODE=true

# 小模型服务自身读取的模型 ID。服务器上可换成 ModelScope 完整模型名或内部镜像路径。
FSMN_VAD_MODEL_ID=fsmn-vad
CAMPP_MODEL_ID=iic/speech_campplus_sv_zh-cn_16k-common
DIARIZATION_MODEL_ID=iic/speech_campplus_speaker-diarization_common
MODEL_DEVICE=cpu
FORCED_ALIGNER_BACKEND_URL=
QWEN_FORCED_ALIGNER_MODEL_ID=
QWEN_FORCED_ALIGNER_DEVICE=cuda:0
# 3D-Speaker 多人分离可本地加载，也可指向算力服务器上的独立服务，例如 http://10.0.0.20:9103。
DIARIZATION_BACKEND_URL=

# 会议 AI：后端本地编排摘要、纪要、待办、翻译、语篇规整，再调用 DeepSeek 输出结构化 JSON。
# AI_MOCK_MODE=true 时不会消耗模型额度，五个前端工具会使用本地规则兜底结果。
AI_PROVIDER=deepseek
AI_MOCK_MODE=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=120

# 普通会议系统对接。没有 token 时后端只生成 taskSave payload，不主动推送。
MEETING_SYSTEM_BASE_URL=
MEETING_SYSTEM_TOKEN=
FFMPEG_BIN=ffmpeg
